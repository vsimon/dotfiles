# Oh-my-zsh setup

DISABLE_AUTO_UPDATE="true"
DISABLE_MAGIC_FUNCTIONS="true"
DISABLE_COMPFIX="true"

# Path to your oh-my-zsh installation.
export ZSH=$HOME/.oh-my-zsh
ZSH_THEME=simple                   #gnzh #kphoen
zstyle ':omz:update' mode disabled # disable automatic updates
plugins=(
  aws
  brew
  direnv
  fzf
  git
  kubectl
  kube-ps1
  terraform
  timer
  tmux
  z
  zsh-autosuggestions
  zsh-syntax-highlighting) # zsh-syntax-highlighting must be at end
source $ZSH/oh-my-zsh.sh

# AWS setup
export AWS_PAGER=""

# Atuin setup
eval "$(atuin init zsh --disable-up-arrow)"

# Brew setup
eval "$(/opt/homebrew/bin/brew shellenv)"

# direnv setup
alias di='echo dotenv > .envrc && touch .env && direnv allow'

# Git setup
alias gl='git log'
alias gf='git fetch --all --prune'
alias gr='git rebase'
alias grom='git rebase $(git symbolic-ref --short refs/remotes/origin/HEAD)'
alias gprune='master=$(basename $(git symbolic-ref --short refs/remotes/origin/HEAD)); git branch --merged $master | grep -v "${master}$" | xargs git branch -d'
alias gsgr='git stash && git fetch && git rebase $(git symbolic-ref --short refs/remotes/origin/HEAD) && git stash pop'
alias gcan='git commit -a --amend --no-edit'
alias gd='git diff'
alias gc='git commit'
alias gs='git status'
export GIT_PAGER='less -FX'

# Go setup
export PATH="$(go env GOPATH)/bin:$PATH"

# K8S setup
export KUBE_EDITOR='cursor -w'
export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"
kall() {
  local filter="" exclude="" ns=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--filter)  filter="$2"; shift 2 ;;
      -e|--exclude) exclude="$2"; shift 2 ;;
      -n|--namespace) ns="$2"; shift 2 ;;
      -h|--help)
        echo "Usage: kall [-f pattern] [-e pattern] [-n namespace] <command...>"
        echo "  -f, --filter    Only include contexts matching pattern"
        echo "  -e, --exclude   Exclude contexts matching pattern"
        echo "  -n, --namespace Set namespace for all contexts"
        return 0 ;;
      *) break ;;
    esac
  done

  local contexts
  contexts=$(kubectl config get-contexts -o name)
  [[ -n "$filter" ]] && contexts=$(echo "$contexts" | grep -E "$filter")
  [[ -n "$exclude" ]] && contexts=$(echo "$contexts" | grep -vE "$exclude")

  while IFS= read -r ctx; do
    [[ -z "$ctx" ]] && continue
    kubie exec "$ctx" "$ns" "$@"
  done <<< "$contexts"
}

# mise setup
eval "$(mise activate zsh)"

# rg setup
alias rg="rg --hidden --glob '!.git'"

# Rust setup
export PATH="$HOME/.cargo/bin:$PATH"

# zsh setup
function get_cluster_short() {
  echo $(echo "$1" | cut -d : -f5)/$(echo "$1" | cut -d / -f2)
}

KUBE_PS1_CLUSTER_FUNCTION=get_cluster_short
KUBE_PS1_HIDE_IF_NOCONTEXT=true
KUBE_PS1_NS_ENABLE=false
KUBE_PS1_PREFIX=
KUBE_PS1_SUFFIX=" "
KUBE_PS1_SYMBOL_ENABLE=false
PROMPT='$(kube_ps1)'$PROMPT
